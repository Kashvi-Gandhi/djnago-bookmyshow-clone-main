# Django Settings
SECRET_KEY=your_django_secret_key_here

# ============================================================================
# STRIPE PAYMENT CONFIGURATION - REQUIRED FOR PAYMENTS!
# ============================================================================
# HOW TO GET THESE KEYS:
# 1. Go to https://dashboard.stripe.com/test/apikeys
# 2. Copy the "Publishable key" (starts with pk_test_) → STRIPE_PUBLIC_KEY
# 3. Copy the "Secret key" (starts with sk_test_) → STRIPE_SECRET_KEY
# 4. For webhooks: Developers → Webhooks → Add endpoint → Copy signing secret

STRIPE_PUBLIC_KEY=pk_test_YOUR_ACTUAL_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_ACTUAL_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE
TICKET_PRICE=250.00
STRIPE_CURRENCY=INR

# ============================================================================
# YOUTUBE DATA API (Optional - trailer auto-lookup)
# ============================================================================
# If a movie has no `trailer_url`, the app can search YouTube for "<movie> trailer"
# and embed the first embeddable result (cached). Create a key for "YouTube Data API v3".
YOUTUBE_API_KEY=

# Optional: change the embed domain used for trailers.
# Default is privacy-friendly `youtube-nocookie`. If embeds show "Video unavailable" only inside
# your site, try switching to the standard embed domain:
# YOUTUBE_EMBED_BASE=https://www.youtube.com/embed/
YOUTUBE_EMBED_BASE=

# ============================================================================
# EMAIL CONFIGURATION (Optional - for booking confirmations)
# ============================================================================
# Option 1: Using SendGrid (Production recommended)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=2525
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.your_sendgrid_api_key_here
EMAIL_USE_TLS=false
EMAIL_USE_SSL=false

# Option 2: Using Gmail (Development only)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-specific-password (generate at myaccount.google.com/apppasswords)
# EMAIL_USE_TLS=true

DEFAULT_FROM_EMAIL=your_email@example.com
